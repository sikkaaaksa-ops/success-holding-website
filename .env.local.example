# ─── Google Sheets Integration ───────────────────────────────────────
# Service account credentials for reading data from Google Sheets
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-here

# ─── Contact Form ────────────────────────────────────────────────────
# Email service for contact form submissions
CONTACT_EMAIL_TO=info@successholding.sa
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ─── WhatsApp ────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=966112345678

# ─── Site Config ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://successholding.sa
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ─── Analytics (optional) ───────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Revalidation ───────────────────────────────────────────────────
# How often (in seconds) to revalidate cached data from Google Sheets
REVALIDATION_INTERVAL=3600
